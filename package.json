{
  "name": "@gigerit/vuetify-date-input-advanced",
  "version": "3.4.0",
  "description": "Advanced Vuetify 4 date picker and input components with multi-month range selection.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gigerIT/vuetify-date-input-advanced.git"
  },
  "homepage": "https://github.com/gigerIT/vuetify-date-input-advanced#readme",
  "bugs": {
    "url": "https://github.com/gigerIT/vuetify-date-input-advanced/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/gigerit-vuetify-date-input-advanced.css",
    "./styles": {
      "sass": "./styles.sass",
      "style": "./dist/gigerit-vuetify-date-input-advanced.css",
      "default": "./dist/gigerit-vuetify-date-input-advanced.css"
    },
    "./styles/variables": {
      "sass": "./styles/_variables.sass",
      "default": "./styles/_variables.sass"
    }
  },
  "files": [
    "dist",
    "src/styles",
    "styles",
    "styles.sass"
  ],
  "sideEffects": [
    "**/*.sass",
    "**/*.scss",
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite --config playground/vite.config.ts",
    "build": "vite build",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "peerDependencies": {
    "vue": "^3.5.0",
    "vuetify": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "@types/node": "^24.3.0",
    "@mdi/font": "^7.4.47",
    "@typescript-eslint/eslint-plugin": "^8.39.1",
    "@typescript-eslint/parser": "^8.39.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitejs/plugin-vue-jsx": "^5.1.1",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.4.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.6.2",
    "resize-observer-polyfill": "^1.5.1",
    "sass": "^1.92.1",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-vuetify": "^2.1.2",
    "vitest": "^3.2.4",
    "vitest-axe": "^0.1.0",
    "vue": "^3.5.18",
    "vue-eslint-parser": "^10.1.0",
    "vue-tsc": "^3.0.5",
    "vuetify": "^4.0.0"
  }
}
